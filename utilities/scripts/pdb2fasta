#!/bin/bash

if [ -z "$1" ]; then
    echo "Usage: $0 /path/to/pdb_folder_or_file"
    exit 1
fi

input_path="$1"
output_file="Fasta_file"
> "$output_file"

# Mapping array
declare -A aa=( 
    [ALA]=A [ARG]=R [ASN]=N [ASP]=D [CYS]=C [GLN]=Q [GLU]=E [GLY]=G [HIS]=H [ILE]=I 
    [LEU]=L [LYS]=K [MET]=M [PHE]=F [PRO]=P [SER]=S [THR]=T [TRP]=W [TYR]=Y [VAL]=V 
)

# Determine if input is a directory or a single file
if [ -d "$input_path" ]; then
    files=("$input_path"/*.pdb)
elif [ -f "$input_path" ]; then
    files=("$input_path")
else
    echo "Error: $input_path is not a valid file or directory."
    exit 1
fi

echo "Extracting sequences..."

for pdb in "${files[@]}"; do
    # Check if there are any files
    [ -e "$pdb" ] || continue
    
    filename=$(basename "$pdb" .pdb)
    echo ">$filename" >> "$output_file"

    # Process ATOM records
    awk '/^ATOM  / { print substr($0, 18, 3), substr($0, 23, 4) }' "$pdb" | uniq | while read -r res_name res_num; do
        if [[ -n ${aa[$res_name]} ]]; then
            printf "%s" "${aa[$res_name]}"
        else
            printf "X" 
        fi
    done >> "$output_file"
    echo "" >> "$output_file"
done

sed -i '/^$/d' "$output_file"

echo "Done! Sequences saved to $output_file"
